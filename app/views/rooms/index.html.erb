<% content_for :title, "room" %>

<div class="w-full max-w-xl mx-auto p-6 bg-white rounded-xl shadow-md border border-slate-100">
  <header class="border-b border-slate-200 pb-4 mb-6">
    <h1 class="text-2xl font-bold text-slate-900">VTalk Rooms</h1>
    <p class="text-sm text-slate-500 mt-1">Select a chat room to join the conversation</p>
  </header>

  <div class="flex flex-col gap-3">
    <% @rooms.each do |room| %>
      <div class="flex items-center justify-between p-4 bg-slate-50 border border-slate-200 rounded-lg hover:bg-slate-100 transition-colors duration-200">
        <div>
          <span class="font-semibold text-slate-700"># <%= room[:name] %></span>
        </div>
        <button class="bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm px-4 py-2 rounded-md transition-colors duration-200">
          Join
        </button>
      </div>
    <% end %>
  </div>
</div>
